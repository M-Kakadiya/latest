{% comment %}
  Section: Wholesale / Bulk Order Request
  File: sections/wholesale-bulk-order.liquid
  
  SETUP:
  - Add this section to any page via the theme customizer
  - Configure which collection to pull products from in section settings
  - Form submits via Shopify Contact Form (no backend needed)
{% endcomment %}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/iconify/1.0.7/iconify.min.css">
<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js" defer></script>

<section class="wholesale-section" id="wholesale-section-{{ section.id }}">
  <div class="fluid_container">

    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="wholesale-section__header">
        {% if section.settings.heading != blank %}
          <h2 class="wholesale-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="wholesale-section__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="wholesale-layout">

      {%- comment -%} ── LEFT: Product Grid ── {%- endcomment -%}
      <div class="wholesale-products">
        <div class="wholesale-products__header">
          <div>
            <h3 class="wholesale-products__title">{{ section.settings.grid_heading | default: 'Select Bulk Products' }}</h3>
            <p class="wholesale-products__count" id="wholesale-count-{{ section.id }}">0 products</p>
          </div>
          <div class="wholesale-selected-badge" id="wholesale-badge-{{ section.id }}">
            <span id="wholesale-badge-count-{{ section.id }}">0</span> selected
          </div>
        </div>

        <div class="wholesale-grid" id="wholesale-grid-{{ section.id }}">
          {%- assign collection = collections[section.settings.collection] -%}
          {%- if collection != blank -%}
            {%- for product in collection.products limit: section.settings.product_limit -%}
              <div
                class="wholesale-card"
                data-product-id="{{ product.id }}"
                data-product-title="{{ product.title | escape }}"
                data-product-price="{{ product.metafields.custom.product_weight_text | escape }}"
                data-product-image="{{ product.featured_image | image_url: width: 400 }}"
                onclick="toggleWholesaleProduct(this, '{{ section.id }}')"
                role="button"
                tabindex="0"
                aria-pressed="false"
              >
                <div class="wholesale-card__check">✓</div>
                <div class="wholesale-card__image">
                  {%- if product.featured_image -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 300 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="300"
                      height="300"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'wholesale-card__placeholder' }}
                  {%- endif -%}
                </div>
                <div class="wholesale-card__body">
                  <p class="wholesale-card__name">{{ product.title }}</p>
                  <p class="wholesale-card__price">{{ product.metafields.custom.product_weight_text }}</p>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="wholesale-card wholesale-card--placeholder">
                <div class="wholesale-card__check">
                  <iconify-icon icon="solar:check-bold" width="14"></iconify-icon>
                </div>
                <div class="wholesale-card__image">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'wholesale-card__placeholder' }}
                </div>
                <div class="wholesale-card__body">
                  <p class="wholesale-card__name">Product {{ i }}</p>
                  <p class="wholesale-card__price">$0.00</p>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ── RIGHT: Quote Form ── {%- endcomment -%}
      <div class="wholesale-sidebar">
        <div class="wholesale-form-card" id="wholesale-form-card-{{ section.id }}">

          <div class="wholesale-form-card__header">
            <h3 class="wholesale-form-card__title">{{ section.settings.form_heading | default: 'Request Custom Quote' }}</h3>
            <p class="wholesale-form-card__subtitle">{{ section.settings.form_subheading | default: "We'll call you back with the best prices" }}</p>
          </div>

          <div class="wholesale-selected-items" id="wholesale-selected-wrap-{{ section.id }}">
            <label class="wholesale-label">Selected Items</label>
            <div class="wholesale-selected-list" id="wholesale-selected-list-{{ section.id }}"></div>
          </div>

          <div id="wholesale-form-{{ section.id }}" class="wholesale-form">
            {%- form 'contact' -%}

              <input type="hidden" name="contact[tags]" value="wholesale-request">
              <input type="hidden" name="contact[selected_products]" id="ws-products-{{ section.id }}" value="">

              <div class="wholesale-field">
                <label class="wholesale-label" for="ws-name-{{ section.id }}">Contact Name *</label>
                <input
                  type="text"
                  id="ws-name-{{ section.id }}"
                  name="contact[name]"
                  required
                  class="wholesale-input"
                  autocomplete="name"
                >
              </div>

              <div class="wholesale-field">
                <label class="wholesale-label" for="ws-business-{{ section.id }}">Business Name</label>
                <input
                  type="text"
                  id="ws-business-{{ section.id }}"
                  name="contact[business]"
                  class="wholesale-input"
                  autocomplete="organization"
                >
              </div>

              {%- comment -%} ★ REQUIRED — Shopify will NOT send any email without contact[email] ★ {%- endcomment -%}
              <div class="wholesale-field">
                <label class="wholesale-label" for="ws-email-{{ section.id }}">Email Address *</label>
                <input
                  type="email"
                  id="ws-email-{{ section.id }}"
                  name="contact[email]"
                  required
                  class="wholesale-input"
                  autocomplete="email"
                >
              </div>

              <div class="wholesale-field">
                <label class="wholesale-label" for="ws-phone-{{ section.id }}">Phone Number *</label>
                <input
                  type="tel"
                  id="ws-phone-{{ section.id }}"
                  name="contact[phone]"
                  required
                  class="wholesale-input"
                  autocomplete="tel"
                >
              </div>

              <div class="wholesale-field">
                <label class="wholesale-label" for="ws-notes-{{ section.id }}">Additional Notes</label>
                <textarea
                  id="ws-notes-{{ section.id }}"
                  name="contact[body]"
                  rows="3"
                  placeholder="Preferred quantities, delivery frequency, etc."
                  class="wholesale-input wholesale-input--textarea"
                ></textarea>
              </div>

              <button
                type="submit"
                id="ws-submit-{{ section.id }}"
                class="wholesale-submit"
                disabled
              >
                {{ section.settings.submit_label | default: 'Select items to continue' }}
              </button>

            {%- endform -%}
          </div>

          <div class="wholesale-success" id="wholesale-success-{{ section.id }}">
            <div class="wholesale-success__icon">
              <iconify-icon icon="solar:check-circle-bold" width="40" class="wholesale-success__icon-svg"></iconify-icon>
            </div>
            <p class="wholesale-success__title">Request Submitted!</p>
            <p class="wholesale-success__subtitle">{{ section.settings.success_message | default: "We'll call you within 24 hours with a quote." }}</p>
            <button onclick="resetWholesaleForm('{{ section.id }}')" class="wholesale-success__reset">
              Submit another request
            </button>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

{%- comment -%} ────────────────── CSS ────────────────── {%- endcomment -%}
<style>
  #wholesale-section-{{ section.id }} {
    --ws-accent: {{ section.settings.accent_color }};
    --ws-accent-dark: {{ section.settings.accent_dark_color }};
    --ws-accent-light: {{ section.settings.accent_light_color }};
    --ws-radius: 8px;
  }

  .wholesale-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .wholesale-section__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .wholesale-section__heading {
    font-size: clamp(24px, 3vw, 38px);
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 8px;
  }
  .wholesale-section__subheading {
    color: #78716c;
    font-size: 15px;
    margin: 0;
  }

  .wholesale-layout {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 1024px) {
    .wholesale-layout {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .wholesale-products {
    flex: 1;
    min-width: 0;
  }
  .wholesale-products__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .wholesale-products__title {
    font-size: 20px;
    font-weight: 700;
    color: #1c1917;
    margin: 0 0 4px;
  }
  .wholesale-products__count {
    font-size: 13px;
    color: #78716c;
    margin: 0;
  }

  .wholesale-selected-badge {
    display: none;
    font-size: 12px;
    font-weight: 600;
    color: var(--ws-accent);
    background: var(--ws-accent-light);
    border: 1px solid color-mix(in srgb, var(--ws-accent) 20%, transparent);
    padding: 4px 12px;
    border-radius: 999px;
  }
  .wholesale-selected-badge.is-visible { display: block; }

  .wholesale-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  @media (min-width: 768px) {
    .wholesale-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
  }

  .wholesale-card {
    position: relative;
    background: #fff;
    border: 2px solid #E7E5E4;
    border-radius: var(--ws-radius);
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
    user-select: none;
    padding: 18px;
  }
  .wholesale-card.is-selected { border-color: var(--ws-accent); }
  .wholesale-card.is-selected .wholesale-card__check {
    opacity: 1;
    transform: scale(1);
  }
  .wholesale-card__check {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    background: var(--ws-accent);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 1;
  }
  .wholesale-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f4;
    border-radius: var(--ws-radius);
  }
  .wholesale-card__image img,
  .wholesale-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
    border-radius: var(--ws-radius);
  }
  .wholesale-card:hover .wholesale-card__image img { transform: scale(1.04); }
  .wholesale-card__body { padding: 12px 0 0 0; }
  .wholesale-card__name {
    font-size: 14px;
    font-weight: 500;
    color: #292524;
    margin: 0 0 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 20px;
  }
  .wholesale-card__price {
    font-size: 10px;
    color: #A8A29E;
    margin: 0;
    line-height: 15px;
  }

  .wholesale-sidebar { width: 100%; }
  @media (min-width: 1024px) {
    .wholesale-sidebar {
      width: 384px;
      flex-shrink: 0;
    }
  }

  .wholesale-form-card {
    position: sticky;
    top: 112px;
    background: #fff;
    border: 1px solid #E7E5E4;
    border-radius: 16px;
    padding: 24px 24px 40px;
  }
  .wholesale-form-card__header { margin-bottom: 20px; }
  .wholesale-form-card__title {
    font-size: 20px;
    color: #1C1917;
    margin: 0 0 4px;
    line-height: 28px;
  }
  .wholesale-form-card__subtitle {
    font-size: 12px;
    color: #78716c;
    margin: 0;
  }

  .wholesale-field input[type="text"],
  .wholesale-field input[type="tel"],
  .wholesale-field input[type="email"] {
    background: #FAFAF9;
    border: 1px solid #E7E5E4;
    border-radius: 8px;
  }

  .wholesale-selected-items {
    display: none;
    margin-bottom: 16px;
  }
  .wholesale-selected-items.is-visible { display: block; }
  .wholesale-selected-list {
    max-height: 160px;
    overflow-y: auto;
    margin-top: 8px;
    margin-bottom: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .wholesale-selected-tag {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    background: #f5f5f4;
    border-radius: 8px;
    padding: 6px 10px;
    color: #1c1917;
  }

  .wholesale-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .wholesale-field {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 12px;
  }
  .wholesale-label {
    font-size: 12px;
    font-weight: 500;
    color: #44403c;
  }
  .wholesale-input {
    width: 100%;
    background: #fafaf9;
    border: 1px solid #e7e5e4;
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 14px;
    color: #1c1917;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
    font-family: inherit;
  }
  .wholesale-input:focus {
    outline: none;
    border-color: var(--ws-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ws-accent) 15%, transparent);
  }
  .wholesale-input--textarea { resize: none; }

  .wholesale-submit {
    width: 100%;
    background: var(--ws-accent-dark);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, opacity 0.2s;
    font-family: inherit;
    margin-top: 4px;
  }
  .wholesale-submit:hover:not(:disabled) {
    background: color-mix(in srgb, var(--ws-accent-dark) 85%, black);
  }
  .wholesale-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .wholesale-success {
    display: none;
    text-align: center;
    padding: 32px 0;
  }
  .wholesale-success.is-visible { display: block; }
  .wholesale-success__icon {
    width: 64px;
    height: 64px;
    background: var(--ws-accent-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }
  .wholesale-success__icon-svg { color: var(--ws-accent); }
  .wholesale-success__title {
    font-size: 15px;
    font-weight: 600;
    color: #1c1917;
    margin: 0 0 4px;
  }
  .wholesale-success__subtitle {
    font-size: 12px;
    color: #78716c;
    margin: 0 0 16px;
  }
  .wholesale-success__reset {
    background: none;
    border: none;
    color: var(--ws-accent);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: underline;
    font-family: inherit;
  }

  @media (max-width: 1024px) {
    .wholesale-card { padding: 14px; }
    .wholesale-layout { gap: 30px; }
    .wholesale-grid { gap: 12px; }
    .wholesale-section { padding: 0 0 80px; }
  }
</style>

{%- comment -%} ────────────────── JS ────────────────── {%- endcomment -%}
<script>
(function() {
  var sectionId = '{{ section.id }}';
  document.addEventListener('DOMContentLoaded', function() {
    var grid = document.getElementById('wholesale-grid-' + sectionId);
    var countEl = document.getElementById('wholesale-count-' + sectionId);
    if (grid && countEl) {
      var total = grid.querySelectorAll('.wholesale-card').length;
      countEl.textContent = total + ' product' + (total !== 1 ? 's' : '');
    }
  });
})();

function toggleWholesaleProduct(card, sectionId) {
  card.classList.toggle('is-selected');
  card.setAttribute('aria-pressed', card.classList.contains('is-selected'));
  updateWholesaleForm(sectionId);
}

function updateWholesaleForm(sectionId) {
  var grid        = document.getElementById('wholesale-grid-' + sectionId);
  var badge       = document.getElementById('wholesale-badge-' + sectionId);
  var badgeCount  = document.getElementById('wholesale-badge-count-' + sectionId);
  var listWrap    = document.getElementById('wholesale-selected-wrap-' + sectionId);
  var list        = document.getElementById('wholesale-selected-list-' + sectionId);
  var hiddenInput = document.getElementById('ws-products-' + sectionId);
  var submitBtn   = document.getElementById('ws-submit-' + sectionId);

  var selected = grid ? grid.querySelectorAll('.wholesale-card.is-selected') : [];
  var count = selected.length;

  if (badge) {
    badge.classList.toggle('is-visible', count > 0);
    if (badgeCount) badgeCount.textContent = count;
  }

  if (listWrap) listWrap.classList.toggle('is-visible', count > 0);
  if (list) {
    list.innerHTML = '';
    selected.forEach(function(card) {
      var tag = document.createElement('div');
      tag.className = 'wholesale-selected-tag';
      tag.innerHTML = '<span>' + card.dataset.productTitle + '</span><span>' + card.dataset.productPrice + '</span>';
      list.appendChild(tag);
    });
  }

  if (hiddenInput) {
    var items = Array.from(selected).map(function(c) {
      var title  = c.dataset.productTitle;
      var weight = c.dataset.productPrice;
      return weight ? title + ' (' + weight + ')' : title;
    });
    hiddenInput.value = items.join(', ');
  }

  if (submitBtn) {
    submitBtn.disabled = count === 0;
    submitBtn.textContent = count === 0
      ? 'Select items to continue'
      : 'Request Quote (' + count + ' item' + (count !== 1 ? 's' : '') + ')';
  }
}

function resetWholesaleForm(sectionId) {
  var grid = document.getElementById('wholesale-grid-' + sectionId);
  if (grid) {
    grid.querySelectorAll('.wholesale-card.is-selected').forEach(function(c) {
      c.classList.remove('is-selected');
      c.setAttribute('aria-pressed', 'false');
    });
  }
  var success     = document.getElementById('wholesale-success-' + sectionId);
  var formWrapper = document.getElementById('wholesale-form-' + sectionId);
  if (success) success.classList.remove('is-visible');
  if (formWrapper) formWrapper.style.display = '';
  updateWholesaleForm(sectionId);
}

document.addEventListener('DOMContentLoaded', function() {
  var sectionId   = '{{ section.id }}';
  var wrapper     = document.getElementById('wholesale-form-' + sectionId);
  if (!wrapper) return;

  var form = wrapper.querySelector('form');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    // Merge selected products into the body field so they appear in the email
    var hiddenInput = document.getElementById('ws-products-' + sectionId);
    var bodyField   = form.querySelector('textarea[name="contact[body]"]');
    if (hiddenInput && hiddenInput.value && bodyField) {
      var existing = bodyField.value.trim();
      bodyField.value = 'Selected Products: ' + hiddenInput.value + (existing ? '\n\nNotes: ' + existing : '');
    }

    var params = new URLSearchParams(new FormData(form));

    fetch('/contact', {
      method: 'POST',
      body: params.toString(),
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-Requested-With': 'XMLHttpRequest'
      }
    })
    .then(function(response) {
      if (response.ok) {
        wrapper.style.display = 'none';
        var success = document.getElementById('wholesale-success-' + sectionId);
        if (success) success.classList.add('is-visible');
      } else {
        form.submit();
      }
    })
    .catch(function() {
      form.submit();
    });
  });
});
</script>

{% schema %}
{
  "name": "Wholesale Bulk Order",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Wholesale & Bulk Orders"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section subheading",
      "default": "Get the best prices for large orders"
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Grid heading",
      "default": "Select Bulk Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Products collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Max products to show",
      "min": 3, "max": 24, "step": 3,
      "default": 9
    },
    {
      "type": "text",
      "id": "form_heading",
      "label": "Form heading",
      "default": "Request Custom Quote"
    },
    {
      "type": "text",
      "id": "form_subheading",
      "label": "Form subheading",
      "default": "We'll call you back with the best prices"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Select items to continue"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "We'll call you within 24 hours with a quote."
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#059669"
    },
    {
      "type": "color",
      "id": "accent_dark_color",
      "label": "Accent dark (button)",
      "default": "#065f46"
    },
    {
      "type": "color",
      "id": "accent_light_color",
      "label": "Accent light (backgrounds)",
      "default": "#ecfdf5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0, "max": 200, "step": 5,
      "default": 45
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0, "max": 200, "step": 5,
      "default": 135
    }
  ],
  "presets": [
    {
      "name": "Wholesale Bulk Order"
    }
  ]
}
{% endschema %}
